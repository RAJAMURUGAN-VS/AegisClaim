    "statistical_parameters": {
      "description": "Configuration for statistical anomaly detection methods",
      "data": {
        "IQR_METHOD": {
          "name": "Interquartile Range",
          "use_case": "Detect billing amount outliers",
          "iqr_multiplier": 1.5,
          "formula": "Q3 + (1.5 * IQR) = upper_bound; Q1 - (1.5 * IQR) = lower_bound",
          "minimum_sample_size": 10,
          "threshold": "Values beyond bounds flagged as HIGH severity"
        },
        "Z_SCORE_METHOD": {
          "name": "Standard Deviation",
          "use_case": "Detect frequency anomalies",
          "z_score_threshold": 2.0,
          "formula": "(value - mean) / stddev",
          "minimum_sample_size": 20,
          "threshold": "|z-score| > 2.0 = anomaly (2.58 for 99% confident)"
        },
        "PERCENTILE_METHOD": {
          "name": "Percentile Ranking",
          "use_case": "Detect provider behavior vs peers",
          "percentile_threshold": 95,
          "formula": "rank(provider) / total_providers * 100",
          "minimum_sample_size": 50,
          "threshold": "Percentile > 95 = HIGH risk provider"
        },
        "FREQUENCY_SPIKE_DETECTION": {
          "name": "Year-over-Year Growth",
          "use_case": "Detect sudden changes in billing frequency",
          "threshold_pct": 50,
          "formula": "((current_year - prior_year) / prior_year) * 100",
          "minimum_sample_size": 12,
          "threshold": "Growth > 50% = MEDIUM severity flag"
        }
      }
    },
