    "cpt_bundling_groups": {
      "table_name": "cpt_bundling_groups",
      "description": "Groups of CPT codes with bundling rules",
      "schema": {
        "group_id": {
          "type": "UUID",
          "primary_key": true
        },
        "group_name": {
          "type": "VARCHAR(100)"
        },
        "cpt_codes": {
          "type": "JSONB",
          "description": "Array of CPT codes in this group"
        },
        "bundle_type": {
          "type": "VARCHAR(50)",
          "enum": ["MUTUALLY_EXCLUSIVE", "PARENT_CHILD", "UNBUNDLING", "FREQUENCY_LIMITED"]
        },
        "rule_description": {
          "type": "TEXT"
        },
        "is_active": {
          "type": "BOOLEAN",
          "default": true
        },
        "created_at": {
          "type": "TIMESTAMP",
          "default": "now()"
        }
      },
      "sample_records": [
        {
          "group_id": "uuid-group-001",
          "group_name": "Office Visit Levels",
          "cpt_codes": ["99213", "99214", "99215"],
          "bundle_type": "MUTUALLY_EXCLUSIVE",
          "rule_description": "Select only one office visit level per encounter",
          "is_active": true,
          "created_at": "2024-02-10T08:00:00Z"
        },
        {
          "group_id": "uuid-group-002",
          "group_name": "CT Head Studies",
