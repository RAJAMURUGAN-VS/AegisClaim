          "created_at": "2024-03-15T08:00:00Z"
        }
      ]
    },
    "specialty_billing_thresholds": {
      "table_name": "specialty_billing_thresholds",
      "description": "Specialty-specific thresholds for anomaly detection (impossible billing)",
      "schema": {
        "threshold_id": {
          "type": "UUID",
          "primary_key": true
        },
        "specialty": {
          "type": "VARCHAR(50)",
          "nullable": false
        },
        "max_claims_per_day": {
          "type": "INTEGER",
          "description": "Maximum reasonable claims per day for this specialty"
        },
        "max_claims_per_week": {
          "type": "INTEGER"
        },
        "avg_billing_amount": {
          "type": "NUMERIC(10,2)",
          "description": "Average billing amount for peer group"
        },
        "payer_id": {
          "type": "UUID",
          "foreign_key": "payer_master.payer_id",
          "nullable": true
        },
        "is_active": {
          "type": "BOOLEAN",
          "default": true
        },
        "created_at": {
          "type": "TIMESTAMP",
          "default": "now()"
        }
      },
      "sample_records": [
        {
          "threshold_id": "uuid-specialty-001",
