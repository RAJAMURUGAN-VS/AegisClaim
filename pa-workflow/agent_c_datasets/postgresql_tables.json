        },
        {
          "group_id": "uuid-group-003",
          "group_name": "Spirometry Tests",
          "cpt_codes": ["94010", "94060"],
          "bundle_type": "FREQUENCY_LIMITED",
          "rule_description": "Spirometry with and without bronchodilator - limit frequency",
          "is_active": true,
          "created_at": "2024-02-10T08:00:00Z"
        },
        {
          "group_id": "uuid-group-004",
          "group_name": "ER and Critical Care",
          "cpt_codes": ["99285", "99291", "99292"],
