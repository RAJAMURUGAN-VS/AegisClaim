{
  "postgresql_tables": {
    "bundled_cpt_rules": {
      "table_name": "bundled_cpt_rules",
      "description": "Rules defining CPT codes that should not be billed together (unbundling detection)",
      "schema": {
        "rule_id": {
          "type": "UUID",
          "primary_key": true,
          "default": "uuid.uuid4()"
        },
        "primary_cpt": {
          "type": "VARCHAR(16)",
          "nullable": false
        },
        "secondary_cpt": {
          "type": "VARCHAR(16)",
          "nullable": false
        },
        "rule_description": {
          "type": "TEXT",
          "nullable": true
        },
        "payer_id": {
          "type": "UUID",
          "foreign_key": "payer_master.payer_id",
          "nullable": true
        },
        "is_active": {
          "type": "BOOLEAN",
          "default": true
        },
        "created_at": {
          "type": "TIMESTAMP",
          "default": "now()"
        }
      },
      "sample_records": [
        {
          "rule_id": "uuid-bundled-001",
          "primary_cpt": "99214",
          "secondary_cpt": "99291",
          "rule_description": "Cannot bill office visit with critical care on same day",
          "payer_id": "uuid-aetna-001",
          "is_active": true,
          "created_at": "2024-01-15T08:00:00Z"
        },
        {
          "rule_id": "uuid-bundled-002",
          "primary_cpt": "70450",
          "secondary_cpt": "70460",
          "rule_description": "CT head with contrast and without contrast - bill only one",
          "payer_id": "uuid-aetna-001",
          "is_active": true,
          "created_at": "2024-01-15T08:00:00Z"
        },
        {
          "rule_id": "uuid-bundled-003",
          "primary_cpt": "99213",
          "secondary_cpt": "99214",
          "rule_description": "New vs established patient office visit - select one only",
          "payer_id": "uuid-united-001",
          "is_active": true,
          "created_at": "2024-01-15T08:00:00Z"
        },
        {
          "rule_id": "uuid-bundled-004",
          "primary_cpt": "94010",
          "secondary_cpt": "94060",
          "rule_description": "Spirometry with and without bronchodilator - cannot bill same day",
          "payer_id": "uuid-cigna-001",
          "is_active": true,
          "created_at": "2024-01-15T08:00:00Z"
        },
        {
          "rule_id": "uuid-bundled-005",
          "primary_cpt": "99285",
          "secondary_cpt": "99291",
          "rule_description": "ER visit and critical care - cannot bill together",
          "payer_id": null,
          "is_active": true,
          "created_at": "2024-01-15T08:00:00Z"
        }
      ]
    },
    "fraud_detection_config": {
      "table_name": "fraud_detection_config",
      "description": "Configurable fraud detection weights and thresholds per payer",
      "schema": {
        "config_id": {
          "type": "UUID",
          "primary_key": true
        },
        "payer_id": {
          "type": "UUID",
          "foreign_key": "payer_master.payer_id",
          "nullable": false
        },
        "anomaly_type": {
          "type": "VARCHAR(50)",
          "nullable": false,
          "enum": ["DUPLICATE_CLAIM", "HIGH_FREQUENCY", "UPCODING_DETECTED", "POTENTIAL_UNBUNDLING", "IMPOSSIBLE_DAY_BILLING", "FREQUENCY_SPIKE", "PROVIDER_RISK_ADJUSTMENT", "CLAIM_REVERSAL_RATE"]
        },
        "base_deduction": {
          "type": "NUMERIC(5,2)",
          "description": "Base score deduction (negative value)"
        },
        "severity_multiplier": {
          "type": "JSONB",
          "example": {
            "LOW": 0.5,
            "MEDIUM": 1.0,
            "HIGH": 1.5
          }
        },
        "statistical_threshold": {
          "type": "NUMERIC(5,2)",
          "description": "For IQR method: 1.5, Z-score: 2.0, Percentile: 75"
        },
        "is_active": {
          "type": "BOOLEAN",
          "default": true
        },
        "effective_date": {
          "type": "DATE"
        },
        "created_at": {
          "type": "TIMESTAMP",
          "default": "now()"
        }
      },
      "sample_records": [
        {
          "config_id": "uuid-fraud-config-001",
          "payer_id": "uuid-aetna-001",
          "anomaly_type": "DUPLICATE_CLAIM",
          "base_deduction": -25.0,
          "severity_multiplier": {"LOW": 0.5, "MEDIUM": 1.0, "HIGH": 1.5},
          "statistical_threshold": null,
          "is_active": true,
          "effective_date": "2024-04-01",
          "created_at": "2024-03-15T08:00:00Z"
        },
        {
          "config_id": "uuid-fraud-config-002",
          "payer_id": "uuid-aetna-001",
          "anomaly_type": "UPCODING_DETECTED",
          "base_deduction": -25.0,
          "severity_multiplier": {"LOW": 0.5, "MEDIUM": 1.0, "HIGH": 1.5},
          "statistical_threshold": 1.5,
          "is_active": true,
          "effective_date": "2024-04-01",
          "created_at": "2024-03-15T08:00:00Z"
        },
        {
          "config_id": "uuid-fraud-config-003",
          "payer_id": "uuid-aetna-001",
          "anomaly_type": "POTENTIAL_UNBUNDLING",
          "base_deduction": -20.0,
          "severity_multiplier": {"LOW": 0.5, "MEDIUM": 1.0, "HIGH": 1.5},
          "statistical_threshold": null,
          "is_active": true,
          "effective_date": "2024-04-01",
          "created_at": "2024-03-15T08:00:00Z"
        },
        {
          "config_id": "uuid-fraud-config-004",
          "payer_id": "uuid-aetna-001",
          "anomaly_type": "IMPOSSIBLE_DAY_BILLING",
          "base_deduction": -30.0,
          "severity_multiplier": {"LOW": 0.5, "MEDIUM": 1.0, "HIGH": 1.5},
          "statistical_threshold": null,
          "is_active": true,
          "effective_date": "2024-04-01",
          "created_at": "2024-03-15T08:00:00Z"
        },
        {
          "config_id": "uuid-fraud-config-005",
          "payer_id": "uuid-aetna-001",
          "anomaly_type": "PROVIDER_RISK_ADJUSTMENT",
          "base_deduction": -30.0,
          "severity_multiplier": {"LOW": 0.25, "MEDIUM": 0.5, "HIGH": 1.0},
