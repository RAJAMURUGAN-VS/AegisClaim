# App
ENVIRONMENT=dev
SECRET_KEY=your-super-secret-key-change-this

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pa_workflow_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=pa_workflow

# Redis
REDIS_URL=redis://localhost:6379

# AWS (use dummy values for now — real values needed for OCR)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
AWS_S3_BUCKET_NAME=pa-workflow-bucket

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRY_MINUTES=60

# Twilio (dummy for now)
TWILIO_ACCOUNT_SID=dummy
TWILIO_AUTH_TOKEN=dummy
TWILIO_FROM_NUMBER=+10000000000

# SMTP (dummy for now)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dummy@gmail.com
SMTP_PASSWORD=dummy

# --- AI/Business Logic Settings ---
OCR_CONFIDENCE_THRESHOLD=0.7
SCORE_AUTO_APPROVE_THRESHOLD=85
SCORE_HUMAN_REVIEW_MIN_THRESHOLD=60

